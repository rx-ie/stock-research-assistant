result = collect_ticker_data(TICKER)

print("=" * 100)
print("STRUCTURED STOCK DATA")
print("=" * 100)
print(json.dumps(result, indent=2))

print("\n" + "=" * 100)
print("PROMPT TO PASTE INTO AI CHATBOT")
print("=" * 100)
print(build_chatbot_prompt(result))
